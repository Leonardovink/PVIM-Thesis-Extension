#!/bin/bash
#SBATCH --job-name=smoke_infer
#SBATCH --partition=gpu_h100
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=12
#SBATCH --gpus=1
#SBATCH --mem=128G
#SBATCH --time=00:45:00
#SBATCH --output=logs/smoke_infer_%j.out
#SBATCH --error=logs/smoke_infer_%j.err

# Cheap end-to-end smoke test (~20 min, ~70 SBU): saved adapter + a few val
# samples. If it prints SMOKE TEST OK, launch the ablation array.

export PYTHONUNBUFFERED=1
set -ue

module purge
module load 2023
module load TensorFlow/2.15.1-foss-2023a-CUDA-12.1.1
module load PyTorch/2.1.2-foss-2023a-CUDA-12.1.1

cd /scratch-shared/$USER/PVIM-Thesis
mkdir -p logs
source .venv-qwen/bin/activate
export PYTHONNOUSERSITE=1
find .venv-qwen -exec touch -h {} + 2>/dev/null || true   # keep venv timestamps fresh
export PYTHONPATH="$PWD:$PWD/future_work:${PYTHONPATH:-}"
export TRANSFORMERS_OFFLINE=1
export HF_HUB_OFFLINE=1
QWEN_MODEL="${QWEN_MODEL:-/scratch-shared/$USER/PVIM-Thesis/models/Qwen2.5-VL-32B-Instruct}"

echo "=== Smoke inference test - Start: $(date) ==="
nvidia-smi --query-gpu=name,memory.total,memory.free --format=csv

python -u smoke_infer.py \
    --qwen-model "$QWEN_MODEL" \
    --adapter data/models/lora_2-4s_opt_nopvim

echo ""
echo "=== Done: $(date) ==="
